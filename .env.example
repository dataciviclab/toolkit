# toolkit — Environment Variables (opzionali)
# Copia in .env solo se serve sovrascrivere i default.

# Livello di logging MCP (DEBUG|INFO|WARNING|ERROR)
# DATACIVICLAB_MCP_LOG_LEVEL=INFO

# Override directory output pipeline
# DCL_ROOT=/path/to/output
# TOOLKIT_OUTDIR=/path/to/output
# DCL_OUTDIR=/path/to/output
